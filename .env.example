# ReportServer CE image build args
RS_VERSION=6.1.2
RS_BUILD=6123
RS_ZIP=RS6.1.2-6123-2026-04-16-14-17-01-reportserver-ce.zip

# SHA-256 of the upstream ReportServer CE distribution used during image build.
# Update this if the upstream archive changes.
RS_SHA256=9c2518b737cf614fc1fb420dd34402b8c8628a87912f5442c8f7509da7113a63

# Runtime settings
TZ=America/Bahia
JAVA_XMS=512m
JAVA_XMX=1536m
RS_BASE_URL=http://localhost:8080

# Database connection used by the ReportServer webapp.
# Use a service hostname such as "db" when running with Docker Compose.
RS_DB_TYPE=postgresql
RS_DB_HOST=db
RS_DB_PORT=5432
RS_DB_NAME=reportserver
RS_DB_USER=reportserver
RS_DB_PASSWORD=change-me-reportserver-db-password
RS_CONFIG_DIR=/opt/reportserver/config
RS_DATA_DIR=/var/lib/reportserver
RS_DB_INIT_SCHEMA=true
RS_DB_CONNECT_TIMEOUT=120

# Prefer *_FILE variables for secrets in Compose/Swarm/Kubernetes-style setups.
# If both RS_DB_PASSWORD and RS_DB_PASSWORD_FILE are set, the image entrypoint
# should prefer the file value.
# RS_DB_PASSWORD_FILE=/run/secrets/reportserver_db_password

# Optional database bootstrap values for a bundled PostgreSQL service.
POSTGRES_DB=reportserver
POSTGRES_USER=reportserver
POSTGRES_PASSWORD_FILE=/run/secrets/reportserver_db_password

# Compose uses 8080:8080 by default.
REPORTSERVER_HTTP_PORT=8080
